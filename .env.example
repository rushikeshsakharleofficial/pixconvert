# Server
PORT=4000
TRUST_PROXY=1

# Scaling bounds
APP_MIN_REPLICAS=1
APP_MAX_REPLICAS=10

# Autoscaler thresholds
AUTOSCALE_SERVICE=app
AUTOSCALE_CPU_SCALE_UP=75
AUTOSCALE_CPU_SCALE_DOWN=25
AUTOSCALE_MEM_SCALE_UP=80
AUTOSCALE_MEM_SCALE_DOWN=35
AUTOSCALE_POLL_MS=30000
AUTOSCALE_COOLDOWN_MS=120000

# CORS - comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com

# File Upload
MAX_FILE_SIZE_MB=50
MAX_FILES_PER_UPLOAD=50

# Admin API Key (required for /api/files listing endpoint)
ADMIN_API_KEY=your-secret-admin-key

# SMTP Email Configuration
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
ADMIN_EMAIL=admin@your-domain.com
FROM_EMAIL=noreply@your-domain.com
